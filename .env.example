# --- Server ---
PORT=3001
# Where the SQLite file lives. Use an absolute path on a persistent volume in production.
DATABASE_PATH=./data/monitor.sqlite
# How often to ping httpbin (cron syntax). Default: every 5 minutes.
# Tip: set to "* * * * *" locally to watch real-time updates without waiting.
PING_CRON=*/5 * * * *
# Target endpoint (overridable for testing / demos)
PING_URL=https://httpbin.org/anything
# Request timeout for the ping, in milliseconds
PING_TIMEOUT_MS=10000

# --- LLM (Option B: LLM-Powered Insights) ---
# Optional. Without a key the app runs fine; chat + incident analysis fall back
# to deterministic (non-LLM) summaries.
ANTHROPIC_API_KEY=
# Hard cap on LLM calls per rolling hour (assignment requirement: 20)
LLM_CALLS_PER_HOUR=20

# --- Web (Vite) ---
# Base URL of the API server as seen from the browser. Leave empty for
# same-origin (production build served by the server) or the Vite dev proxy.
VITE_API_BASE=
